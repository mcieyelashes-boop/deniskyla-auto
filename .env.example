# Server-side only (Vercel env var, never VITE_ prefix):
ANTHROPIC_API_KEY=your_api_key_here

# Boolean flag only — set to "true" to enable AI mode, never put the actual key here:
VITE_HAS_API_KEY=true

# Optional: restrict API calls to your domain
ALLOWED_ORIGIN=https://your-domain.vercel.app

# Supabase (optional — enables cloud sync across devices)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Webhook trigger authentication
TRIGGER_KEYS=your_secret_key_here

# Cron authentication
CRON_SECRET=your_cron_secret_here
